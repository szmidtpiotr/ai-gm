services:
  ollama:
    image: ollama/ollama:latest
    restart: unless-stopped
    ports:
      - "11434:11434"
    volumes:
      - ollama:/root/.ollama
    environment:
      NVIDIA_VISIBLE_DEVICES: all
      NVIDIA_DRIVER_CAPABILITIES: compute,utility
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    networks:
      - ai-gm
    healthcheck:
      test: ["CMD-SHELL", "bash -c 'exec 3<>/dev/tcp/127.0.0.1/11434'"]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 20s

  backend:
    build:
      context: ./backend
    restart: unless-stopped
    ports:
      - "8000:8000"
    environment:
      OLLAMA_BASE_URL: ${OLLAMA_BASE_URL:-http://ollama:11434}
      OLLAMA_TIMEOUT: ${OLLAMA_TIMEOUT:-60}
      DEFAULT_CAMPAIGN_LANGUAGE: ${DEFAULT_CAMPAIGN_LANGUAGE:-pl}
      GAME_LANG: ${GAME_LANG:-pl-PL}
      DATABASE_URL: ${DATABASE_URL:-sqlite:////data/ai_gm.db}

    volumes:
      - ai_gm_data:/data
    depends_on:
      ollama:
        condition: service_healthy
    networks:
      - ai-gm

  frontend:
    image: nginx:alpine
    restart: unless-stopped
    ports:
      - "3001:80"
    volumes:
      - ./frontend:/usr/share/nginx/html:ro
      - ./frontend/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - backend
    networks:
      - ai-gm

volumes:
  ollama:
  ai_gm_data:

networks:
  ai-gm:
    driver: bridge
