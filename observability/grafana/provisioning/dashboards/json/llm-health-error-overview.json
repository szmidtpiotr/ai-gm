{
  "id": null,
  "uid": "ai-gm-llm-health",
  "title": "AI GM - LLM Health & Error Overview",
  "tags": ["ai-gm", "llm", "errors"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 99,
      "type": "stat",
      "title": "Backend requests (10m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} |= \"request_complete\" [10m]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Total Errors / min",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", level=~\"error|warn\"}[1m]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Auth Errors / min",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", error_type=\"llm_auth_error\"}[1m]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Connect Errors / min",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", error_type=\"llm_connect_error\"}[1m]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Errors / min",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", error_type=\"llm_http_error\"}[1m]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent LLM Errors",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"error|warn\"}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 }
    }
  ]
}
