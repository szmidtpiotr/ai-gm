{
  "id": null,
  "uid": "ai-gm-location-integrity",
  "title": "AI GM - Location Integrity",
  "tags": ["ai-gm", "loki", "location-integrity"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(service)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": true,
          "text": "backend",
          "value": "backend"
        }
      },
      {
        "name": "campaign_id",
        "label": "Campaign ID",
        "type": "textbox",
        "query": ".+",
        "current": {
          "text": ".+",
          "value": ".+"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Integrity events (total)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} | json | event=~\"location_integrity_.*\" | campaign_id=~\"$campaign_id\" [$__range]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Blocked moves",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} | json | event=\"location_integrity_apply_blocked\" | campaign_id=~\"$campaign_id\" [$__range]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Location updates",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} | json | event=\"location_integrity_apply_location_updated\" | campaign_id=~\"$campaign_id\" [$__range]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dynamic locations created",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} | json | event=\"location_integrity_dynamic_location_created\" | campaign_id=~\"$campaign_id\" [$__range]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Blocked vs updated over time",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (event) (count_over_time({service=~\"$service\"} | json | event=~\"location_integrity_apply_blocked|location_integrity_apply_location_updated\" | campaign_id=~\"$campaign_id\" [$__interval]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Validator decisions over time",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (event) (count_over_time({service=~\"$service\"} | json | event=~\"location_integrity_validate_.*\" | campaign_id=~\"$campaign_id\" [$__interval]))",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Location Integrity event stream",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | event=~\"location_integrity_.*\" | campaign_id=~\"$campaign_id\"",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 }
    }
  ]
}
