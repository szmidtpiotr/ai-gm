          "expr": "{service=\"backend\"} |= \"memory_turn\" | json | event=\"memory_turn\" | campaign_id=~\"${campaign_id}\" | line_format \"[Kampania {{.campaign_id}} | Tura {{.turn_number}}]\\n\\nPYTANIE:\\n{{.user_text}}\\n\\nOdpowiedz:\\n{{.assistant_text}}\"",
          "queryType": "range",
          "legendFormat": ""
        }
      ]
