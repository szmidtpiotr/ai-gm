# LLM provider type: ollama or openai
LLM_PROVIDER=ollama

# LLM server base URL (for ollama: host:11434, for openai: API base)
LLM_BASE_URL=http://host.docker.internal:11434

# Default model name used by backend if not provided per-request
LLM_MODEL=gemma4:e4b

# Optional API key / bearer token; leave empty for no auth
LLM_API_KEY=

# Optional: Loki base URL if not set in Admin → Observability (SQLite game_config_meta.loki_url).
# Precedence: database → LOKI_URL → (default http://loki:3100 on first DB migrate).
# LOKI_URL=http://loki:3100
