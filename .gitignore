# Docker
*.log

# DB bind-mount data directory (ignore DB files; keep data/.gitkeep and backups/.gitkeep tracked)
data/*
!data/.gitkeep
backups/*
!backups/.gitkeep
ollama/
__pycache__/
*.pyc
.env
env.test
.secrets/
.DS_Store
.venv/

# NFS stale handles (cannot delete while open elsewhere)
frontend/.nfs*

# Generated by install.sh
install-summary.txt

*.bak

# Ephemeral SQLite sidecars next to pytest DBs under backend/tests/
backend/tests/*.db-shm
backend/tests/*.db-wal

# Local SQLite snapshot for Grafana/MCP (install.sh --with-observability)
observability-data/

# Generated by scripts/db-autosync.sh --install-cron
scripts/.db-autosync-cron-wrap.sh

# Internal local-only documentation
/docs/
/skills/
data-dev/
backend/ai_test_config.json

# Observability DEV - dane runtime (nie commitujemy)
observability-dev/loki/data/
observability-dev/grafana/data/
